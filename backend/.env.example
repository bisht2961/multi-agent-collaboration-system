# ==================== LLM Configuration ====================
# OpenAI API Key (required for openai provider)
OPENAI_API_KEY=sk-your-openai-key-here

# OpenAI model to use (default: gpt-4)
OPENAI_MODEL=gpt-4

# Anthropic API Key (required for anthropic provider)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# Anthropic model to use (default: claude-3-sonnet-20240229)
ANTHROPIC_MODEL=claude-3-sonnet-20240229

# Default LLM provider: 'openai' or 'anthropic' (default: openai)
LLM_PROVIDER=openai

# ==================== Server Configuration ====================
# Application name (default: Multi-Agent Collaboration System)
APP_NAME=Multi-Agent Collaboration System

# Enable debug mode (default: false)
DEBUG=false

# Server host address (default: 0.0.0.0)
HOST=0.0.0.0

# Server port (default: 8000)
PORT=8000

# ==================== Agent Configuration ====================
# Maximum number of agents (default: 10)
MAX_AGENTS=10

# Agent execution timeout in seconds (default: 300)
AGENT_TIMEOUT=300

# ==================== Task Configuration ====================
# Maximum number of retries for failed tasks (default: 3)
MAX_RETRIES=3

# Maximum concurrent tasks (default: 5)
MAX_CONCURRENT_TASKS=5

# ==================== Logging Configuration ====================
# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL (default: INFO)
LOG_LEVEL=INFO

# Log format string
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# ==================== Database Configuration (Optional) ====================
# Database connection URL (optional)
# DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# ==================== Other Settings ====================
# Environment: 'development', 'staging', or 'production' (default: development)
ENVIRONMENT=development

